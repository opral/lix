{
  "name": "vscode-docs-replay",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Replay the first 100 vscode-docs commits into a .lix sqlite file",
  "scripts": {
    "bootstrap": "node ./src/bootstrap.js",
    "replay:raw": "pnpm --filter @lix-js/better-sqlite3-backend run build && node ./src/replay.js",
    "analyze:raw": "pnpm --filter @lix-js/better-sqlite3-backend run build && node ./src/analyze.js",
    "analyze-file-types:raw": "pnpm --filter @lix-js/better-sqlite3-backend run build && node ./src/analyze-file-types.js",
    "bench:raw": "pnpm --filter @lix-js/better-sqlite3-backend run build && node ./src/bench.js",
    "reset:raw": "node ./src/reset.js",
    "cli": "node ./src/cli.js",
    "replay": "pnpm run cli -- replay",
    "analyze": "pnpm run cli -- analyze",
    "analyze-file-types": "pnpm run cli -- analyze-file-types",
    "bench": "pnpm run cli -- bench",
    "reset": "pnpm run cli -- reset",
    "run": "pnpm run replay"
  },
  "dependencies": {
    "@lix-js/better-sqlite3-backend": "workspace:*",
    "@lix-js/sdk": "workspace:*"
  }
}
