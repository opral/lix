{
  "x-lix-key": "lix_directory_descriptor",
  "x-lix-primary-key": [
    "/id"
  ],
  "x-lix-unique": [
    [
      "/parent_id",
      "/name"
    ]
  ],
  "x-lix-foreign-keys": [
    {
      "properties": [
        "/parent_id"
      ],
      "references": {
        "schemaKey": "lix_directory_descriptor",
        "properties": [
          "/id"
        ]
      }
    }
  ],
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "x-lix-default": "lix_uuid_v7()"
    },
    "parent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$"
    }
  },
  "required": [
    "id",
    "parent_id",
    "name"
  ],
  "additionalProperties": false
}
