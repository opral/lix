{
  "x-lix-key": "lix_file_descriptor",
  "x-lix-version": "1",
  "x-lix-primary-key": [
    "/id"
  ],
  "x-lix-unique": [
    [
      "/directory_id",
      "/name",
      "/extension"
    ]
  ],
  "x-lix-foreign-keys": [
    {
      "properties": [
        "/directory_id"
      ],
      "references": {
        "schemaKey": "lix_directory_descriptor",
        "properties": [
          "/id"
        ]
      }
    }
  ],
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "x-lix-default": "lix_uuid_v7()"
    },
    "directory_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$"
    },
    "extension": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[^./\\\\]+$"
    },
    "hidden": {
      "type": "boolean",
      "x-lix-default": "false"
    }
  },
  "required": [
    "id",
    "directory_id",
    "name",
    "extension"
  ],
  "additionalProperties": false
}
