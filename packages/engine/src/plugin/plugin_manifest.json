{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "key",
    "runtime",
    "api_version",
    "match",
    "entry",
    "schemas"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "runtime": {
            "const": "wasm-component-v2"
          }
        },
        "required": ["runtime"]
      },
      "then": {
        "properties": {
          "api_version": {
            "const": "2.0.0"
          }
        }
      }
    }
  ],
  "properties": {
    "key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "runtime": {
      "type": "string",
      "enum": [
        "wasm-component-v1",
        "wasm-component-v2"
      ]
    },
    "api_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_glob"],
      "properties": {
        "path_glob": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "content_type": {
          "type": "string",
          "enum": ["text", "binary"]
        }
      }
    },
    "entry": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "schemas": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    }
  }
}
